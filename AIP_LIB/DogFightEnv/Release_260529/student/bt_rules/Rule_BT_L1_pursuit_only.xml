<!--
  BT difficulty ladder L1: PURSUIT-ONLY (no defensive maneuvers).

  Derived from the stock Rule_forTraining.xml (backup: Rule_BT_L4_stock.xml).
  Removed branches: HardRearBreakTurn, RearThreatJink, BreakTurn, LowYoYo.
  Kept: ClimbRecover (altitude safety), CloseRecommit, FarRecommit,
  GunLeadPursuit, LagPursuit branches.

  Purpose: a live opponent that always turns toward the agent and SHOOTS
  (GunLeadPursuit inside 950m / LOS<30) but never defends its six. Lets the
  agent bring its mastered 500-900m rear-saddle gunnery to a reactive,
  shooting target WITHOUT triggering the known tick-0 defensive suicide-dive
  (Task_DefensiveBreak / Task_RearThreatJink are the dive triggers; they are
  absent here, so close rear spawns are safe again).

  Activate by copying over the workspace-root Rule_forTraining.xml before
  launching training (the BT DLL reads the root file). run_eval can pin it
  directly via - -bt-rule-xml student/bt_rules/Rule_BT_L1_pursuit_only.xml
-->
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence>
      <SelectTarget name="SelectTarget" BB="{BB}"/>
      <DirectionVectorUpdate name="DirectionVectorUpdate" BB="{BB}"/>
      <DistanceUpdate name="DistanceUpdate" BB="{BB}"/>
      <CheckSight name="CheckSight" BB="{BB}"/>
      <AngleOffUpdate name="AngleOffUpdate" BB="{BB}"/>
      <AspectAngleUpdate name="AspectAngleUpdate" BB="{BB}"/>

      <Fallback>
        <Sequence>
          <DECO_AltitudeCheck name="LowAltitudeCheck" UpDown="Less" Altitude="1800" BB="{BB}"/>
          <Task_ClimbRecover name="ClimbRecover" MinAltitude="2500" ForwardDistance="4500" BB="{BB}"/>
        </Sequence>

        <Sequence>
          <DECO_DistanceCheck name="OvershootRangeCheck" UpDown="Less" Distance="750" BB="{BB}"/>
          <DECO_LOSCheck name="LostNoseCheck" UpDown="Greater" InputLOS="55" BB="{BB}"/>
          <Task_Recommit name="CloseRecommit" LeadDistance="1300" VerticalOffset="120" BB="{BB}"/>
        </Sequence>

        <Sequence>
          <DECO_DistanceCheck name="FarRecommitCheck" UpDown="Greater" Distance="2500" BB="{BB}"/>
          <Task_Recommit name="FarRecommit" LeadDistance="1700" VerticalOffset="150" BB="{BB}"/>
        </Sequence>

        <Sequence>
          <DECO_LOSCheck name="NoseOnTargetCheck" UpDown="Less" InputLOS="30" BB="{BB}"/>
          <DECO_DistanceCheck name="InsideWeaponsRangeCheck" UpDown="Less" Distance="950" BB="{BB}"/>
          <Task_LeadPursuit name="GunLeadPursuit" MaxLeadDistance="1100" VerticalOffset="40" BB="{BB}"/>
        </Sequence>

        <Sequence>
          <DECO_DistanceCheck name="MidFightCheck" UpDown="Less" Distance="2500" BB="{BB}"/>
          <Task_LagPursuit name="LagPursuit" LagDistance="650" VerticalOffset="80" BB="{BB}"/>
        </Sequence>

        <Task_LagPursuit name="LagPursuitDefault" LagDistance="500" VerticalOffset="80" BB="{BB}"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>
</root>
